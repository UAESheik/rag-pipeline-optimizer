{
  "search_space": {
    "chunking": {
      "strategy": ["token", "sentence", "semantic"],
      "size": [128, 256, 384, 512],
      "overlap_type": ["token", "sentence"],
      "overlap_size": [64, 100, 128],
      "semantic_min_size": [350],
      "semantic_max_size": [650],
      "window_size": [3, 5],
      "similarity_threshold": [0.55, 0.65],
      "preserve_table_as_markdown": [false, true],
      "generate_image_caption": [false, true]
    },
    "retrieval": {
      "retriever": ["bm25", "dense", "hybrid"],
      "embedding_model": ["bge-small", "e5-base"],
      "metadata_filter_enabled": [false, true],
      "metadata_filter_fields": ["section_title", "type"],
      "metadata_enrichment": [false, true]
    },
    "reranking": {
      "enabled": [false, true],
      "model": ["bge-reranker-base", "cross-encoder/ms-marco-MiniLM-L-6-v2"]
    },
    "query_processor": {
      "rewrite": [false, true],
      "decompose": [false, true],
      "intent_driven_filter": [false, true]
    },
    "generation": {
      "temperature": [0.0, 0.2],
      "answer_style": ["concise", "citation_first"]
    }
  },
  "objective": {
    "case1_weights": {
      "context_recall": 0.42,
      "answer_similarity": 0.32,
      "faithfulness": 0.24,
      "answer_relevancy": 0.01,
      "context_relevancy": 0.01
    },
    "case2_weights": {
      "retrieval_coverage_proxy": 0.1,
      "groundedness": 0.5,
      "citation_quality": 0.35,
      "answer_relevancy": 0.03,
      "context_relevancy": 0.02
    },
    "judge_weight": 0.01
  },
  "run": {
    "random_seed": 42,
    "max_trials": 80,
    "top_k": 6,
    "cache_enabled": false,
    "search_method": "bayes",
    "use_bertscore": true,
    "mlflow_enabled": true,
    "mlflow_tracking_uri": "sqlite:///outputs/mlflow.db",
    "use_llm_judge": true,
    "use_llm_generator": true,
    "llm_model": "qwen2.5:3b-instruct"
  }
}
